# ============================================
# GeneBoyleSkills — .gitignore
# Tailored for a Claude AI skills repository
# ============================================

# === OS artifacts ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# === Editor/IDE ===
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# === Secrets & credentials ===
# NEVER commit tokens, keys, or credentials
.env
.env.*
!.env.example
*.pem
*.key
*.secret
credentials.json
token.txt

# === Temporary files ===
tmp/
temp/
*.tmp
*.bak
*.orig

# === Build artifacts (if scripts are added later) ===
node_modules/
__pycache__/
*.pyc
dist/
build/

# === Skill development artifacts ===
# Test outputs and evaluation workspaces
*-workspace/
iteration-*/
eval-results/

# === Packaged skills (regenerate from source) ===
*.skill

# === Large files that shouldn't be in git ===
*.pdf
*.xlsx
*.docx
*.pptx
*.zip
*.tar.gz
*.mp4
*.mov
